{
  "name": "kanbeasy",
  "private": true,
  "version": "1.53.2",
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:analyze": "ANALYZE=true vite build",
    "build:clean": "rm -rf node_modules && rm -rf dist && rm -rf coverage && rm -rf test-results && rm -rf .lighthouseci && rm -rf playwright-report",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "preview": "npm run build && vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "type:check": "tsc --noEmit",
    "static-checks": "npm run format:check && npm run lint && npm run knip && npm run type:check && npm run build && npm run test:run",
    "knip": "knip",
    "lighthouse": "npx @lhci/cli autorun --collect.startServerCommand='npx vite preview' --collect.startServerReadyPattern='Local' --collect.url='http://localhost:4173' --config=lighthouserc.json",
    "lighthouse:report": "open .lighthouseci/lhr-*.html",
    "kitchen-sink": "npm run static-checks && npm run lighthouse && npm run e2e",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:visual": "playwright test tests-e2e/visual-regression.spec.ts",
    "e2e:snapshot": "playwright test tests-e2e/visual-regression.spec.ts --update-snapshots",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@testing-library/dom": "^10.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.17.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-testing-library": "^7.16.2",
    "fake-indexeddb": "^6.2.5",
    "fuse.js": "^7.4.2",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "knip": "^5.88.1",
    "marked": "^17.0.6",
    "prettier": "^3.8.4",
    "react-doctor": "^0.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
